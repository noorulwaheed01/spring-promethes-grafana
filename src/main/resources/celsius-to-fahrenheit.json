{
  "request": {
    "method": "POST",
    "url": "/temperature",
    "headers": {
      "Content-Type": {
        "contains": "text/xml"
      }
    },
    "bodyPatterns": [
      {
        "matchesXPath": "//*[local-name()='CelsiusToFahrenheitRequest']"
      }
    ]
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "text/xml; charset=UTF-8"
    },
    "body": "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<soap:Envelope xmlns:soap=\"http://schemas.xmlsoap.org/soap/envelope/\" xmlns:tem=\"http://example.com/temperature\">\n   <soap:Body>\n      <tem:CelsiusToFahrenheitResponse>\n         <fahrenheit>77.0</fahrenheit>\n      </tem:CelsiusToFahrenheitResponse>\n   </soap:Body>\n</soap:Envelope>"
  }
}